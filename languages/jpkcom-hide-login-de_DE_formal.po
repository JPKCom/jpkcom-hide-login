#: jpkcom-hide-login.php:70
msgid "JPKCom Hide Login requires PHP 8.3 or higher."
msgstr "JPKCom Hide Login benötigt PHP 8.3 oder höher."

#: jpkcom-hide-login.php:71 jpkcom-hide-login.php:80
msgid "Plugin Deactivated"
msgstr "Plugin deaktiviert"

#: jpkcom-hide-login.php:79
msgid "JPKCom Hide Login requires WordPress 6.8 or higher."
msgstr "JPKCom Hide Login benötigt WordPress 6.8 oder höher."

#: jpkcom-hide-login.php:260
msgid "(network-wide setting active)"
msgstr "(netzwerkweite Einstellung aktiv)"

#: jpkcom-hide-login.php:266
msgid "JPKCom Hide Login activated! Your new login URL:"
msgstr "JPKCom Hide Login aktiviert! Ihre neue Login-URL:"

#: jpkcom-hide-login.php:305
msgid "JPKCom Hide Login"
msgstr "JPKCom Hide Login"

#: jpkcom-hide-login.php:309
#, php-format
msgid "%d IP is currently blocked due to multiple failed login attempts."
msgid_plural "%d IPs are currently blocked due to multiple failed login attempts."
msgstr[0] "%d IP-Adresse ist derzeit aufgrund mehrerer fehlgeschlagener Login-Versuche gesperrt."
msgstr[1] "%d IP-Adressen sind derzeit aufgrund mehrerer fehlgeschlagener Login-Versuche gesperrt."

#: jpkcom-hide-login.php:331
msgid "JPKCom Hide Login (Network)"
msgstr "JPKCom Hide Login (Netzwerk)"

#: jpkcom-hide-login.php:332
msgid "Hide Login (Network)"
msgstr "Login verbergen (Netzwerk)"

#: jpkcom-hide-login.php:357
msgid "Network slug removed. Sites will use their own settings."
msgstr "Netzwerk-Slug entfernt. Websites verwenden ihre eigenen Einstellungen."

#: jpkcom-hide-login.php:365
msgid "Network slug updated."
msgstr "Netzwerk-Slug aktualisiert."

#: jpkcom-hide-login.php:376
msgid "JPKCom Hide Login — Network Settings"
msgstr "JPKCom Hide Login — Netzwerkeinstellungen"

#: jpkcom-hide-login.php:385
msgid "Network-wide login slug"
msgstr "Netzwerkweiter Login-Slug"

#: jpkcom-hide-login.php:398
msgid "Set a network-wide login slug. Leave empty to let each site use its own slug."
msgstr "Legen Sie einen netzwerkweiten Login-Slug fest. Lassen Sie das Feld leer, damit jede Website ihren eigenen Slug verwenden kann."

#: jpkcom-hide-login.php:404
msgid "Save Network Settings"
msgstr "Netzwerkeinstellungen speichern"

#: includes/class-mask-login.php:212
msgid "Page not found."
msgstr "Seite nicht gefunden."

#: includes/class-mask-login.php:213
msgid "404 Not Found"
msgstr "404 Nicht gefunden"

#: includes/class-login-protection.php:142
#, php-format
msgid "Too many failed login attempts. Please try again in %d minutes."
msgstr "Zu viele fehlgeschlagene Login-Versuche. Bitte versuchen Sie es in %d Minuten erneut."

#: includes/class-login-protection.php:169
#, php-format
msgid "%d login attempt remaining."
msgid_plural "%d login attempts remaining."
msgstr[0] "%d Login-Versuch verbleibend."
msgstr[1] "%d Login-Versuche verbleibend."

#: includes/class-admin-settings.php:111
msgid "JPKCom Hide Login Settings"
msgstr "JPKCom Hide Login Einstellungen"

#: includes/class-admin-settings.php:112
msgid "Hide Login"
msgstr "Login verbergen"

#: includes/class-admin-settings.php:200
msgid "The slug you have provided cannot be used. Please try a different one."
msgstr "Der angegebene Slug kann nicht verwendet werden. Bitte versuchen Sie einen anderen."

#: includes/class-admin-settings.php:212
msgid "A page or post already exists with this URL. Please choose a different slug."
msgstr "Eine Seite oder ein Beitrag mit dieser URL existiert bereits. Bitte wählen Sie einen anderen Slug."

#: includes/class-admin-settings.php:241
msgid "Maximum login attempts must be at least 1."
msgstr "Die maximale Anzahl der Login-Versuche muss mindestens 1 betragen."

#: includes/class-admin-settings.php:251
msgid "Maximum login attempts cannot exceed 100."
msgstr "Die maximale Anzahl der Login-Versuche darf 100 nicht überschreiten."

#: includes/class-admin-settings.php:277
msgid "Attempt window must be at least 1 second."
msgstr "Das Zeitfenster für Versuche muss mindestens 1 Sekunde betragen."

#: includes/class-admin-settings.php:287
msgid "Attempt window cannot exceed 3600 seconds (1 hour)."
msgstr "Das Zeitfenster für Versuche darf 3600 Sekunden (1 Stunde) nicht überschreiten."

#: includes/class-admin-settings.php:313
msgid "Block duration must be at least 1 second."
msgstr "Die Sperrdauer muss mindestens 1 Sekunde betragen."

#: includes/class-admin-settings.php:323
msgid "Block duration cannot exceed 86400 seconds (24 hours)."
msgstr "Die Sperrdauer darf 86400 Sekunden (24 Stunden) nicht überschreiten."

#: includes/class-admin-settings.php:388
msgid "Custom Login URL Slug"
msgstr "Benutzerdefinierter Login-URL-Slug"

#: includes/class-admin-settings.php:405
#, php-format
msgid "Your current login URL: %s"
msgstr "Ihre aktuelle Login-URL: %s"

#: includes/class-admin-settings.php:414
msgid "Save Changes"
msgstr "Änderungen speichern"

#: includes/class-admin-settings.php:420
msgid "Brute Force Protection Settings"
msgstr "Brute-Force-Schutz Einstellungen"

#: includes/class-admin-settings.php:431
msgid "Maximum Login Attempts"
msgstr "Maximale Login-Versuche"

#: includes/class-admin-settings.php:446
msgid "Number of failed login attempts before an IP is blocked (1-100). Default: 5"
msgstr "Anzahl fehlgeschlagener Login-Versuche, bevor eine IP-Adresse gesperrt wird (1-100). Standard: 5"

#: includes/class-admin-settings.php:453
msgid "Attempt Window (seconds)"
msgstr "Versuchszeitfenster (Sekunden)"

#: includes/class-admin-settings.php:468
msgid "Time window for counting failed attempts in seconds (1-3600). Default: 60"
msgstr "Zeitfenster zum Zählen fehlgeschlagener Versuche in Sekunden (1-3600). Standard: 60"

#: includes/class-admin-settings.php:475
msgid "Block Duration (seconds)"
msgstr "Sperrdauer (Sekunden)"

#: includes/class-admin-settings.php:493
#, php-format
msgid "How long to block an IP after max attempts in seconds (1-86400). Default: 600 (%d minutes)"
msgstr "Wie lange eine IP-Adresse nach maximalen Versuchen gesperrt wird, in Sekunden (1-86400). Standard: 600 (%d Minuten)"

#: includes/class-admin-settings.php:502
msgid "Save Brute Force Settings"
msgstr "Brute-Force-Einstellungen speichern"

#: includes/class-admin-settings.php:508
msgid "Brute Force Protection Status"
msgstr "Brute-Force-Schutz Status"

#: includes/class-admin-settings.php:511
msgid "Current Status"
msgstr "Aktueller Status"

#: includes/class-admin-settings.php:517
#, php-format
msgid "Active - IPs are blocked for %2$d minutes after %1$d failed login attempts"
msgstr "Aktiv - IP-Adressen werden für %2$d Minuten nach %1$d fehlgeschlagenen Login-Versuchen gesperrt"

#: includes/class-admin-settings.php:527
msgid "Currently Blocked IPs"
msgstr "Aktuell gesperrte IP-Adressen"

#: includes/class-admin-settings.php:532
msgid "IP Address"
msgstr "IP-Adresse"

#: includes/class-admin-settings.php:533
msgid "Blocked At"
msgstr "Gesperrt am"

#: includes/class-admin-settings.php:534
msgid "Expires At"
msgstr "Läuft ab am"

#: includes/class-admin-settings.php:535
msgid "Time Remaining"
msgstr "Verbleibende Zeit"

#: includes/class-admin-settings.php:544
msgid "Hidden"
msgstr "Verborgen"

#: includes/class-admin-settings.php:560
msgid "Clear All Blocked IPs"
msgstr "Alle gesperrten IP-Adressen löschen"

#: includes/class-admin-settings.php:565
msgid "No IPs are currently blocked."
msgstr "Derzeit sind keine IP-Adressen gesperrt."

#: includes/class-admin-settings.php:571
msgid "IP Whitelist"
msgstr "IP-Whitelist"

#: includes/class-admin-settings.php:572
msgid "Whitelisted IP addresses will never be blocked by brute force protection. Supports CIDR notation (e.g., 192.168.1.0/24)."
msgstr "Whitelisted IP-Adressen werden nie durch den Brute-Force-Schutz gesperrt. Unterstützt CIDR-Notation (z.B. 192.168.1.0/24)."

#: includes/class-admin-settings.php:576
msgid "Your Current IP"
msgstr "Ihre aktuelle IP-Adresse"

#: includes/class-admin-settings.php:580
msgid "Whitelisted"
msgstr "Auf Whitelist"

#: includes/class-admin-settings.php:587
msgid "Add IP to Whitelist"
msgstr "IP-Adresse zur Whitelist hinzufügen"

#: includes/class-admin-settings.php:595
msgid "IP Address or CIDR Range"
msgstr "IP-Adresse oder CIDR-Bereich"

#: includes/class-admin-settings.php:608
msgid "Enter a single IP address or a CIDR range."
msgstr "Geben Sie eine einzelne IP-Adresse oder einen CIDR-Bereich ein."

#: includes/class-admin-settings.php:613
msgid "Add to Whitelist"
msgstr "Zur Whitelist hinzufügen"

#: includes/class-admin-settings.php:618
msgid "Current Whitelist"
msgstr "Aktuelle Whitelist"

#: includes/class-admin-settings.php:622
msgid "IP Address / Range"
msgstr "IP-Adresse / Bereich"

#: includes/class-admin-settings.php:623
msgid "Actions"
msgstr "Aktionen"

#: includes/class-admin-settings.php:636
msgid "Remove"
msgstr "Entfernen"

#: includes/class-admin-settings.php:645
msgid "No IPs are currently whitelisted."
msgstr "Derzeit sind keine IP-Adressen auf der Whitelist."

#: includes/class-admin-settings.php:658 includes/class-admin-settings.php:681 includes/class-admin-settings.php:719
msgid "Unauthorized access."
msgstr "Unbefugter Zugriff."

#: includes/class-admin-settings.php:757
msgid "All blocked IPs have been cleared successfully."
msgstr "Alle gesperrten IP-Adressen wurden erfolgreich gelöscht."

#: includes/class-admin-settings.php:761
msgid "IP address added to whitelist successfully."
msgstr "IP-Adresse erfolgreich zur Whitelist hinzugefügt."

#: includes/class-admin-settings.php:765
msgid "IP address removed from whitelist successfully."
msgstr "IP-Adresse erfolgreich von der Whitelist entfernt."

#: includes/class-admin-settings.php:769
msgid "Invalid IP address or CIDR range."
msgstr "Ungültige IP-Adresse oder CIDR-Bereich."

#: includes/class-admin-settings.php:773
msgid "Please enter an IP address."
msgstr "Bitte geben Sie eine IP-Adresse ein."

#: includes/class-plugin-updater.php:410 includes/class-plugin-updater.php:427
#, php-format
msgid "Download failed: %s"
msgstr "Download fehlgeschlagen: %s"

#: includes/class-plugin-updater.php:426
